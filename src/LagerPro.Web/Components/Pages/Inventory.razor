@page "/inventory"
@using LagerPro.Web.Models
@using LagerPro.Web.Services
@inject ApiService Api

<h3>Lageroversikt</h3>

@if (loading)
{
    <p>Laster...</p>
}
else if (error != null)
{
    <p class="text-danger">@error</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ArtikkelNr</th>
                <th>Navn</th>
                <th>LotNr</th>
                <th>Beholdning</th>
                <th>Enhet</th>
                <th>Utløpsdato</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in beholdning)
            {
                <tr>
                    <td>@item.ArtikkelNr</td>
                    <td>@item.ArtikkelNavn</td>
                    <td>@item.LotNr</td>
                    <td>@item.Mengde.ToString("N2")</td>
                    <td>@item.Enhet</td>
                    <td>@(item.BestForDato?.ToString("yyyy-MM-dd") ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<LagerBeholdning> beholdning = new();
    private bool loading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadBeholdning();
    }

    private async Task LoadBeholdning()
    {
        loading = true;
        error = null;
        try
        {
            beholdning = await Api.GetLagerBeholdningAsync();
        }
        catch (Exception ex)
        {
            error = $"Kunne ikke laste lagerbeholdning: {ex.Message}";
        }
        loading = false;
    }
}
