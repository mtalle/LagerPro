@page "/mottak"
@using LagerPro.Web.Models
@using LagerPro.Web.Services
@inject ApiService Api

<h3>Mottak</h3>

@if (loading)
{
    <p>Laster...</p>
}
else if (error != null)
{
    <p class="text-danger">@error</p>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ShowCreateModal">Nytt mottak</button>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Leverandør</th>
                <th>Dato</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var mottak in mottakList)
            {
                <tr>
                    <td>@mottak.Id</td>
                    <td>@mottak.LeverandorNavn</td>
                    <td>@mottak.MottaksDato.ToString("yyyy-MM-dd")</td>
                    <td>@mottak.Status</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick="() => ViewMottak(mottak.Id)">Detaljer</button>
                        @if (mottak.Status == "Mottatt")
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => GodkjennMottak(mottak.Id)">Godkjenn</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(viewingMottak != null ? "Mottak-detaljer" : "Nytt mottak")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (viewingMottak != null)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">Leverandør</dt>
                            <dd class="col-sm-9">@viewingMottak.LeverandorNavn</dd>
                            <dt class="col-sm-3">Dato</dt>
                            <dd class="col-sm-9">@viewingMottak.MottaksDato.ToString("yyyy-MM-dd")</dd>
                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">@viewingMottak.Status</dd>
                        </dl>
                        <h6>Linjer</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr><th>Artikkel</th><th>Mengde</th><th>Enhet</th><th>LotNr</th><th>BestFor</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var linje in viewingMottak.Linjer)
                                {
                                    <tr>
                                        <td>@linje.ArtikkelNavn</td>
                                        <td>@linje.Mengde.ToString("N2")</td>
                                        <td>@linje.Enhet</td>
                                        <td>@linje.LotNr</td>
                                        <td>@(linje.BestForDato?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label>Leverandør</label>
                            <select class="form-select" @bind="newMottak.LeverandorId">
                                <option value="0">Velg leverandør...</option>
                                @foreach (var l in leverandorer)
                                {
                                    <option value="@l.Id">@l.Navn</option>
                                }
                            </select>
                        </div>
                        <h6>Linjer</h6>
                        @foreach (var linje in newMottak.Linjer)
                        {
                            <div class="row mb-2">
                                <div class="col">
                                    <select class="form-select" @bind="linje.ArtikkelId">
                                        <option value="0">Velg artikkel...</option>
                                        @foreach (var a in artikler)
                                        {
                                            <option value="@a.Id">@a.Navn (@a.ArtikkelNr)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-2">
                                    <input class="form-control" type="number" step="0.01" placeholder="Mengde" @bind="linje.Mengde" />
                                </div>
                                <div class="col-2">
                                    <input class="form-control" placeholder="LotNr" @bind="linje.LotNr" />
                                </div>
                                <div class="col-2">
                                    <input class="form-control" type="date" @bind="linje.BestForDato" />
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-danger" @onclick="() => RemoveLinje(linje)">X</button>
                                </div>
                            </div>
                        }
                        <button class="btn btn-secondary" @onclick="AddLinje">+ Legg til linje</button>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Lukk</button>
                    @if (viewingMottak == null)
                    {
                        <button type="button" class="btn btn-primary" @onclick="CreateMottak">Opprett</button>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<Mottak> mottakList = new();
    private List<Article> artikler = new();
    private List<Leverandor> leverandorer = new();
    private bool loading = true;
    private string? error;
    private bool showModal = false;
    private Mottak? viewingMottak;
    private CreateMottakRequest newMottak = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            mottakList = await Api.GetMottakListAsync();
            artikler = await Api.GetArticlesAsync();
            leverandorer = await Api.GetLeverandørerAsync();
        }
        catch (Exception ex)
        {
            error = $"Kunne ikke laste data: {ex.Message}";
        }
        loading = false;
    }

    private void ShowCreateModal()
    {
        newMottak = new CreateMottakRequest();
        newMottak.Linjer.Add(new CreateMottakLinjeRequest());
        viewingMottak = null;
        showModal = true;
    }

    private async Task ViewMottak(int id)
    {
        viewingMottak = await Api.GetMottakByIdAsync(id);
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        viewingMottak = null;
    }

    private void AddLinje()
    {
        newMottak.Linjer.Add(new CreateMottakLinjeRequest());
    }

    private void RemoveLinje(CreateMottakLinjeRequest linje)
    {
        newMottak.Linjer.Remove(linje);
    }

    private async Task CreateMottak()
    {
        try
        {
            await Api.CreateMottakAsync(newMottak);
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved opprettelse: {ex.Message}";
        }
    }

    private async Task GodkjennMottak(int id)
    {
        try
        {
            await Api.UpdateMottakStatusAsync(id, "Godkjent");
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved godkjenning: {ex.Message}";
        }
    }
}
