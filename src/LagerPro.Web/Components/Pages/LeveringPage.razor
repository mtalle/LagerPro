@page "/levering"
@using LagerPro.Web.Models
@using LagerPro.Web.Services
@inject ApiService Api

<h3>Levering</h3>

@if (loading)
{
    <p>Laster...</p>
}
else if (error != null)
{
    <p class="text-danger">@error</p>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ShowCreateModal">Ny levering</button>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Kunde</th>
                <th>Dato</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var levering in leveringList)
            {
                <tr>
                    <td>@levering.Id</td>
                    <td>@levering.KundeNavn</td>
                    <td>@levering.LeveringsDato.ToString("yyyy-MM-dd")</td>
                    <td>@levering.Status</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick="() => ViewLevering(levering.Id)">Detaljer</button>
                        @if (levering.Status == "Klar")
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => SendLevering(levering.Id)">Send</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(viewingLevering != null ? "Levering-detaljer" : "Ny levering")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (viewingLevering != null)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">Kunde</dt>
                            <dd class="col-sm-9">@viewingLevering.KundeNavn</dd>
                            <dt class="col-sm-3">Dato</dt>
                            <dd class="col-sm-9">@viewingLevering.LeveringsDato.ToString("yyyy-MM-dd")</dd>
                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">@viewingLevering.Status</dd>
                            <dt class="col-sm-3">Referanse</dt>
                            <dd class="col-sm-9">@(viewingLevering.Referanse ?? "-")</dd>
                            <dt class="col-sm-3">FraktBrev</dt>
                            <dd class="col-sm-9">@(viewingLevering.FraktBrev ?? "-")</dd>
                        </dl>
                        <h6>Linjer</h6>
                        <table class="table table-sm">
                            <thead><tr><th>Artikkel</th><th>Mengde</th><th>Enhet</th><th>LotNr</th></tr></thead>
                            <tbody>
                                @foreach (var linje in viewingLevering.Linjer)
                                {
                                    <tr>
                                        <td>@linje.ArtikkelNavn</td>
                                        <td>@linje.Mengde.ToString("N2")</td>
                                        <td>@linje.Enhet</td>
                                        <td>@linje.LotNr</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label>Kunde</label>
                            <select class="form-select" @bind="newLevering.KundeId">
                                <option value="0">Velg kunde...</option>
                                @foreach (var k in kunder)
                                {
                                    <option value="@k.Id">@k.Navn</option>
                                }
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label>Leveringsdato</label>
                                <input class="form-control" type="date" @bind="newLevering.LeveringsDato" />
                            </div>
                            <div class="col">
                                <label>Referanse</label>
                                <input class="form-control" placeholder="Referanse" @bind="newLevering.Referanse" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label>FraktBrev</label>
                                <input class="form-control" placeholder="Fraktbrevet er..." @bind="newLevering.FraktBrev" />
                            </div>
                            <div class="col">
                                <label>Kommentar</label>
                                <input class="form-control" placeholder="Kommentar" @bind="newLevering.Kommentar" />
                            </div>
                        </div>
                        <h6>Linjer</h6>
                        @foreach (var linje in newLevering.Linjer)
                        {
                            <div class="row mb-2">
                                <div class="col">
                                    <select class="form-select" @bind="linje.ArtikkelId">
                                        <option value="0">Velg artikkel...</option>
                                        @foreach (var a in artikler)
                                        {
                                            <option value="@a.Id">@a.Navn (@a.ArtikkelNr)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-2">
                                    <input class="form-control" type="number" step="0.01" placeholder="Mengde" @bind="linje.Mengde" />
                                </div>
                                <div class="col-2">
                                    <input class="form-control" placeholder="LotNr" @bind="linje.LotNr" />
                                </div>
                                <div class="col-2">
                                    <select class="form-select" @bind="linje.Enhet">
                                        <option value="">Enhet</option>
                                        <option value="stk">stk</option>
                                        <option value="kg">kg</option>
                                        <option value="L">L</option>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-danger" @onclick="() => RemoveLinje(linje)">X</button>
                                </div>
                            </div>
                        }
                        <button class="btn btn-secondary" @onclick="AddLinje">+ Legg til linje</button>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Lukk</button>
                    @if (viewingLevering == null)
                    {
                        <button type="button" class="btn btn-primary" @onclick="CreateLevering">Opprett</button>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<Levering> leveringList = new();
    private List<Article> artikler = new();
    private List<Kunde> kunder = new();
    private bool loading = true;
    private string? error;
    private bool showModal = false;
    private Levering? viewingLevering;
    private CreateLeveringRequest newLevering = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            leveringList = await Api.GetLeveringListAsync();
            artikler = await Api.GetArticlesAsync();
            kunder = await Api.GetKunderAsync();
        }
        catch (Exception ex)
        {
            error = $"Kunne ikke laste data: {ex.Message}";
        }
        loading = false;
    }

    private void ShowCreateModal()
    {
        newLevering = new CreateLeveringRequest
        {
            LeveringsDato = DateTime.Today
        };
        newLevering.Linjer.Add(new CreateLeveringLinjeRequest());
        viewingLevering = null;
        showModal = true;
    }

    private async Task ViewLevering(int id)
    {
        viewingLevering = await Api.GetLeveringByIdAsync(id);
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        viewingLevering = null;
    }

    private void AddLinje()
    {
        newLevering.Linjer.Add(new CreateLeveringLinjeRequest());
    }

    private void RemoveLinje(CreateLeveringLinjeRequest linje)
    {
        newLevering.Linjer.Remove(linje);
    }

    private async Task CreateLevering()
    {
        try
        {
            if (newLevering.KundeId == 0)
            {
                error = "Velg en kunde.";
                return;
            }
            if (newLevering.Linjer.All(l => l.ArtikkelId == 0))
            {
                error = "Legg til minst én linje.";
                return;
            }
            await Api.CreateLeveringAsync(newLevering);
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved opprettelse: {ex.Message}";
        }
    }

    private async Task SendLevering(int id)
    {
        try
        {
            await Api.UpdateLeveringStatusAsync(id, "Sendt");
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved sending: {ex.Message}";
        }
    }
}
