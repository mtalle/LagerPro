@page "/levering"
@using LagerPro.Web.Models
@using LagerPro.Web.Services
@inject ApiService Api

<h3>Levering</h3>

@if (loading)
{
    <p>Laster...</p>
}
else if (error != null)
{
    <p class="text-danger">@error</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Kunde</th>
                <th>Dato</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var levering in leveringList)
            {
                <tr>
                    <td>@levering.Id</td>
                    <td>@levering.KundeNavn</td>
                    <td>@levering.LeveringsDato.ToString("yyyy-MM-dd")</td>
                    <td>@levering.Status</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick="() => ViewLevering(levering.Id)">Detaljer</button>
                        @if (levering.Status == "Klar")
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => SendLevering(levering.Id)">Send</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(viewingLevering != null ? "Levering-detaljer" : "Ny levering")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (viewingLevering != null)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">Kunde</dt>
                            <dd class="col-sm-9">@viewingLevering.KundeNavn</dd>
                            <dt class="col-sm-3">Dato</dt>
                            <dd class="col-sm-9">@viewingLevering.LeveringsDato.ToString("yyyy-MM-dd")</dd>
                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">@viewingLevering.Status</dd>
                        </dl>
                        <h6>Linjer</h6>
                        <table class="table table-sm">
                            <thead><tr><th>Artikkel</th><th>Mengde</th><th>Enhet</th><th>LotNr</th></tr></thead>
                            <tbody>
                                @foreach (var linje in viewingLevering.Linjer)
                                {
                                    <tr>
                                        <td>@linje.ArtikkelNavn</td>
                                        <td>@linje.Mengde.ToString("N2")</td>
                                        <td>@linje.Enhet</td>
                                        <td>@linje.LotNr</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p>Levering opprettes via API.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Lukk</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<Levering> leveringList = new();
    private bool loading = true;
    private string? error;
    private bool showModal = false;
    private Levering? viewingLevering;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            leveringList = await Api.GetLeveringListAsync();
        }
        catch (Exception ex)
        {
            error = $"Kunne ikke laste data: {ex.Message}";
        }
        loading = false;
    }

    private async Task ViewLevering(int id)
    {
        viewingLevering = await Api.GetLeveringByIdAsync(id);
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        viewingLevering = null;
    }

    private async Task SendLevering(int id)
    {
        try
        {
            await Api.UpdateLeveringStatusAsync(id, "Sendt");
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved sending: {ex.Message}";
        }
    }
}
