@page "/"

<h1>LagerPro</h1>

<p>Velkommen til LagerPro - ditt lagerstyringssystem.</p>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Artikler</h5>
                <p class="card-text">Administrer artikler, priser og beholdning.</p>
                <a href="articles" class="btn btn-primary">Åpne</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Lager</h5>
