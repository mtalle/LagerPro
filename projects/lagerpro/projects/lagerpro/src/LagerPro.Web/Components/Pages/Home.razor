</div>

<div class="row mt-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Produksjon</h5>
                <p class="card-text">Opprett og håndter produksjonsordrer.</p>
                <a href="produksjon" class="btn btn-primary">Åpne</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Levering</h5>
                <p class="card-text">Send ordre til kunder.</p>
                <a href="levering" class="btn btn-primary">Åpne</a>
            </div>
        </div>
    </div>
</div>
