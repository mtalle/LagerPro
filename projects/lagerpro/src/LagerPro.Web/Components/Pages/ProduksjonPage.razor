@page "/produksjon"
@using LagerPro.Web.Models
@using LagerPro.Web.Services
@inject ApiService Api

<h3>Produksjonsordrer</h3>

@if (loading)
{
    <p>Laster...</p>
}
else if (error != null)
{
    <p class="text-danger">@error</p>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ShowCreateModal">Ny produksjonsordre</button>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>OrdreNr</th>
                <th>Artikkel</th>
                <th>Status</th>
                <th>Planlagt</th>
                <th>Ferdigmeldt</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ordre in ordrer)
            {
                <tr>
                    <td>@ordre.OrdreNr</td>
                    <td>@ordre.ReseptNavn</td>
                    <td>@ordre.Status</td>
                    <td>@ordre.PlanlagtDato.ToString("yyyy-MM-dd")</td>
                    <td>@(ordre.FerdigmeldtDato?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick="() => ViewOrdre(ordre.Id)">Detaljer</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(viewingOrdre != null ? "Ordre-detaljer" : "Ny produksjonsordre")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (viewingOrdre != null)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">OrdreNr</dt>
                            <dd class="col-sm-9">@viewingOrdre.OrdreNr</dd>
                            <dt class="col-sm-3">Resept</dt>
                            <dd class="col-sm-9">@viewingOrdre.ReseptNavn</dd>
                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">@viewingOrdre.Status</dd>
                            <dt class="col-sm-3">PlanlagtDato</dt>
                            <dd class="col-sm-9">@viewingOrdre.PlanlagtDato.ToString("yyyy-MM-dd")</dd>
                            <dt class="col-sm-3">FerdigmeldtDato</dt>
                            <dd class="col-sm-9">@(viewingOrdre.FerdigmeldtDato?.ToString("yyyy-MM-dd") ?? "-")</dd>
                            <dt class="col-sm-3">FerdigvareLotNr</dt>
                            <dd class="col-sm-9">@viewingOrdre.FerdigvareLotNr</dd>
                            @if (!string.IsNullOrEmpty(viewingOrdre.Kommentar))
                            {
                                <dt class="col-sm-3">Kommentar</dt>
                                <dd class="col-sm-9">@viewingOrdre.Kommentar</dd>
                            }
                        </dl>

                        @if (viewingOrdreDetaljer?.Forbruk.Any() == true)
                        {
                            <h6>Forbruk</h6>
                            <table class="table table-sm">
                                <thead><tr><th>Artikkel</th><th>Mengde</th><th>Enhet</th><th>LotNr</th></tr></thead>
                                <tbody>
                                    @foreach (var f in viewingOrdreDetaljer.Forbruk)
                                    {
                                        <tr><td>@f.ArtikkelNavn</td><td>@f.Mengde.ToString("N2")</td><td>@f.Enhet</td><td>@f.LotNr</td></tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                    else
                    {
                        <div class="mb-3">
                            <label>Resept</label>
                            <select class="form-select" @bind="newOrdre.ReseptId">
                                <option value="0">Velg resept...</option>
                                @foreach (var r in resepter)
                                {
                                    <option value="@r.Id">@r.Navn</option>
                                }
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label>OrdreNr (valgfritt)</label>
                                <input class="form-control" placeholder="Auto-genereres hvis tom" @bind="newOrdre.OrdreNr" />
                            </div>
                            <div class="col">
                                <label>Planlagt dato</label>
                                <input class="form-control" type="date" @bind="newOrdre.PlanlagtDato" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label>Kommentar</label>
                            <input class="form-control" placeholder="Kommentar (valgfritt)" @bind="newOrdre.Kommentar" />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Lukk</button>
                    @if (viewingOrdre == null)
                    {
                        <button type="button" class="btn btn-primary" @onclick="CreateOrdre">Opprett</button>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<ProduksjonsOrdre> ordrer = new();
    private List<Resept> resepter = new();
    private ProduksjonsOrdreDetaljer? viewingOrdreDetaljer;
    private bool loading = true;
    private string? error;
    private bool showModal = false;
    private ProduksjonsOrdre? viewingOrdre;
    private CreateProduksjonsOrdreRequest newOrdre = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        try
        {
            ordrer = await Api.GetProduksjonsOrdreAsync();
            resepter = await Api.GetResepterAsync();
        }
        catch (Exception ex)
        {
            error = $"Kunne ikke laste data: {ex.Message}";
        }
        loading = false;
    }

    private void ShowCreateModal()
    {
        newOrdre = new CreateProduksjonsOrdreRequest
        {
            PlanlagtDato = DateTime.Today
        };
        viewingOrdre = null;
        viewingOrdreDetaljer = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        viewingOrdre = null;
        viewingOrdreDetaljer = null;
    }

    private async Task ViewOrdre(int id)
    {
        viewingOrdre = ordrer.FirstOrDefault(x => x.Id == id);
        if (viewingOrdre != null)
        {
            viewingOrdreDetaljer = await Api.GetProduksjonsOrdreDetaljerAsync(id);
        }
        showModal = true;
    }

    private async Task CreateOrdre()
    {
        try
        {
            if (newOrdre.ReseptId == 0)
            {
                error = "Velg en resept.";
                return;
            }
            await Api.CreateProduksjonsOrdreAsync(newOrdre);
            CloseModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Feil ved opprettelse: {ex.Message}";
        }
    }
}
